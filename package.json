{
  "name": "artisan-furniture",
  "version": "0.1.0",
  "private": true,
  "description": "Artisan Furniture Co. — Premium handcrafted furniture platform",
  "scripts": {
    "dev:api": "pnpm --filter @artisan/api dev",
    "dev:dashboard": "pnpm --filter @artisan/dashboard dev",
    "dev:agents": "pnpm --filter @artisan/agents dev",
    "mcp": "pnpm --filter @artisan/api mcp",
    "test": "pnpm --filter @artisan/api test",
    "test:agents": "pnpm --filter @artisan/agents test",
    "db:generate": "pnpm --filter @artisan/db generate",
    "db:migrate": "pnpm --filter @artisan/db migrate",
    "db:seed": "pnpm --filter @artisan/db seed"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
